# Copy to .env for local dev, or set these as Environment Variables in Vercel.
# Never commit the real .env.

# --- Weaviate (testimony vector database) ---
# Local dev (server/api/weaviate-proxy.js builds the URL from these):
WEAVIATE_HOST=acg-floating-204-197-5-43.acg.maine.edu
WEAVIATE_PORT=8080
WEAVIATE_SCHEME=http
# Vercel (api/weaviate.js uses the full GraphQL URL instead):
WEAVIATE_URL=http://acg-floating-204-197-5-43.acg.maine.edu:8080/v1/graphql
# Shared by both:
WEAVIATE_API_KEY=your-weaviate-key
# WEAVIATE_TIMEOUT_MS=30000

# --- Query embedding (Hugging Face Inference API) ---
# The search query is embedded server-side via HF feature-extraction on
# sentence-transformers/LaBSE (exact parity with the indexed corpus).
# The token stays server-side only.
HF_TOKEN=your-hf-token
# EMBED_MODEL=sentence-transformers/LaBSE
# EMBED_HF_URL=  # full override for the inference endpoint (optional)

# --- Access gate (HTTP Basic Auth via middleware.js on Vercel) ---
# Shared username/password required to view the deployed site. Set these as
# Vercel Environment Variables too. If either is unset, the gate is off.
USERNAME=changeme
PASSWORD=changeme

# --- Optional ---
# CORS_ALLOW_ORIGIN=*
