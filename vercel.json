{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run generate",
  "outputDirectory": "dist",
  "build": {
    "env": {
      "NODE_OPTIONS": "--openssl-legacy-provider"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/200.html" }
  ],
  "git": {
    "deploymentEnabled": {
      "main": false
    }
  }
}
